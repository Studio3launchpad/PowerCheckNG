model UnitPurchase {
 id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
//  invoiceId     String   @unique
//  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  meterNumber   String
  discoCode     String
  units         Float    // kWh delivered by token vendor
  token         String?  // prepaid meter token (encrypted at rest in app layer)
  vendorRef     String?
  deliveredAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([userId])
}

// ---------- Backup Systems ----------
model BackupSystem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        BackupType
  capacityKwh Float?
  fuelLevel   Float?   // 0..1 for generators
  batteryPct  Float?   // 0..1 for inverters
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum BackupType {
  GENERATOR
  INVERTER
  SOLAR
  HYBRID
}

// ---------- Load Manager ----------
model Load {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  watts       Int
  room        String?
  priority    Int      @default(3) // 1=critical, 5=optional
  isOn        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------- Notifications ----------
model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  body        String
  category    NotificationCategory
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, readAt])
}

enum NotificationCategory {
  OUTAGE
  PAYMENT
  CONSUMPTION
  SECURITY
  SYSTEM
}

// ---------- AI Insights ----------
model AIInsight {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        String   // e.g. "weekly_summary"
  summary     String
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}
